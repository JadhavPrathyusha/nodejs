<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Available Events | E-Ticketing</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      min-height: 100vh;
      background: linear-gradient(-45deg, #1d2671, #c33764, #6a11cb, #2575fc);
      background-size: 400% 400%;
      animation: gradientBG 12s ease infinite;
      color: #fff;
    }
    @keyframes gradientBG {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    .navbar {
      background: rgba(0, 0, 0, 0.65) !important;
      backdrop-filter: blur(8px);
    }
    h2 {
      font-weight: 600;
      letter-spacing: 1px;
    }
    .event-card {
      background: rgba(255, 255, 255, 0.18);
      backdrop-filter: blur(16px);
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.25);
      transition: all 0.3s ease;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
    }
    .event-card:hover {
      transform: translateY(-8px) scale(1.02);
      box-shadow: 0 20px 45px rgba(0, 0, 0, 0.5);
    }
    .price {
      font-size: 1.3rem;
      font-weight: 600;
      margin-bottom: 15px;
    }
    .btn-warning {
      border-radius: 30px;
      font-weight: 600;
      padding: 8px 25px;
      box-shadow: 0 5px 15px rgba(255, 193, 7, 0.5);
    }
    .btn-warning:hover {
      box-shadow: 0 8px 25px rgba(255, 193, 7, 0.8);
      transform: translateY(-2px);
    }
  </style>
</head>
<body>
<nav class="navbar navbar-dark">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold">🎟️ E-Ticketing System</a>
  </div>
</nav>
<div class="container mt-5">
  <h2 class="text-center mb-5">Available Events</h2>
  <div class="row g-4 justify-content-center">
    <div class="col-md-4 col-sm-10">
      <div class="card event-card p-4 text-center h-100">
        <h4>🎬 Movie Ticket</h4>
        <p class="price">₹200</p>
        <button class="btn btn-warning"
          onclick="bookEvent('Movie Ticket', 200)">Add Ticket</button>
      </div>
    </div>
    <div class="col-md-4 col-sm-10">
      <div class="card event-card p-4 text-center h-100">
        <h4>🎤 Concert Pass</h4>
        <p class="price">₹1500</p>
        <button class="btn btn-warning"
          onclick="bookEvent('Concert Pass', 1500)">Add Ticket</button>
      </div>
    </div>
    <div class="col-md-4 col-sm-10">
      <div class="card event-card p-4 text-center h-100">
        <h4>🏏 Sports Event</h4>
        <p class="price">₹800</p>
        <button class="btn btn-warning"
          onclick="bookEvent('Sports Event', 800)">Add Ticket</button>
      </div>
    </div>
    <div class="col-md-4 col-sm-10">
      <div class="card event-card p-4 text-center h-100">
        <h4>🎭 Theatre Show</h4>
        <p class="price">₹500</p>
        <button class="btn btn-warning"
          onclick="bookEvent('Theatre Show', 500)">Add Ticket</button>
      </div>
    </div>
    <div class="col-md-4 col-sm-10">
      <div class="card event-card p-4 text-center h-100">
        <h4>😂 Stand-up Comedy</h4>
        <p class="price">₹700</p>
        <button class="btn btn-warning"
          onclick="bookEvent('Stand-up Comedy', 700)">Add Ticket</button>
      </div>
    </div>
    <div class="col-md-4 col-sm-10">
      <div class="card event-card p-4 text-center h-100">
        <h4>🎨 Art Exhibition</h4>
        <p class="price">₹300</p>
        <button class="btn btn-warning"
          onclick="bookEvent('Art Exhibition', 300)">Add Ticket</button>
      </div>
    </div>
  </div>
</div>
<script>
  function bookEvent(eventName, price) {
    alert(
      `Event: ${eventName}\nPrice: ₹${price}\n\nTicket added successfully!`
    );
  }
</script>

</body>
</html>

